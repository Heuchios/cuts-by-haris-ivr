PORT=3000

# Public HTTPS URL Twilio can reach, for example from ngrok:
# PUBLIC_BASE_URL=https://example.ngrok-free.app
PUBLIC_BASE_URL=

# Twilio Text-to-Speech voice. Polly.Joanna sounds less robotic than alice.
TWILIO_TTS_VOICE=Polly.Joanna
TWILIO_TTS_LANGUAGE=en-US
TWILIO_TTS_RATE=90%
TWILIO_MENU_OPTION_PAUSE=450ms

# Optional smart SMS routing. Normal texts forward here; booking starts with "book".
OWNER_PHONE_NUMBER=

# Setmore live booking. Keep disabled until API access/keys are ready.
SETMORE_ENABLED=false
SETMORE_API_BASE_URL=https://developer.setmore.com
SETMORE_CLIENT_ID=
SETMORE_CLIENT_SECRET=
SETMORE_REFRESH_TOKEN=
SETMORE_STAFF_KEY=
SETMORE_STAFF_NAME=
SETMORE_LOOKAHEAD_DAYS=21
SETMORE_SLOT_LIMIT=12

# Preferred: map each local bot service to its Setmore service key.
SETMORE_SERVICE_KEY_SKIN_FADE=
SETMORE_SERVICE_KEY_REGULAR_HAIRCUT_NO_FADE=
SETMORE_SERVICE_KEY_HAIRCUT_AND_BEARD=
SETMORE_SERVICE_KEY_BUZZ_CUT=
SETMORE_SERVICE_KEY_LONG_HAIRCUT_SCISSORS=
SETMORE_SERVICE_KEY_REGULAR_BEARD_TRIM_NO_FADE=
SETMORE_SERVICE_KEY_BEARD_TRIM_FADE_RAZOR_LINEUP=
SETMORE_SERVICE_KEY_PERM=
SETMORE_SERVICE_KEY_KIDS_REGULAR_CUT_NO_FADE=
SETMORE_SERVICE_KEY_KIDS_FADE=
SETMORE_SERVICE_KEY_SENIORS=
