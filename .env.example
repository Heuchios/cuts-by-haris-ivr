PORT=3000

# Public HTTPS URL Twilio can reach, for example from ngrok:
# PUBLIC_BASE_URL=https://example.ngrok-free.app
PUBLIC_BASE_URL=

# Twilio Text-to-Speech voice. Polly.Joanna sounds less robotic than alice.
TWILIO_TTS_VOICE=Polly.Joanna
TWILIO_TTS_LANGUAGE=en-US
TWILIO_TTS_RATE=90%

# When Setmore API access is approved, the real adapter will use these.
SETMORE_CLIENT_ID=
SETMORE_CLIENT_SECRET=
SETMORE_REFRESH_TOKEN=
